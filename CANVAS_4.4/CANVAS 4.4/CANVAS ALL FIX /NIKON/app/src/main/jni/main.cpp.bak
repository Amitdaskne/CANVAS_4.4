//==========================================//
void MemoryHacksBy_uKnowSpidy() {
    if (!g_LocalController || !g_LocalPlayer) return;
	//===================================================================================================================//
     if (IpadView) {
        g_LocalPlayer->ThirdPersonCameraComponent->SetFieldOfView(105.0f); 
    }
    
        
    //===================================================================================================================//

	    int kill_message_event_idx = 1000;
        auto VTable = (void **) g_LocalController->VTable;
        auto f_mprotect = [](uintptr_t addr, size_t len, int32_t prot) -> int32_t {
       static_assert(PAGE_SIZE == 4096);
       constexpr size_t page_size = static_cast<size_t>(PAGE_SIZE);
       void* start = reinterpret_cast<void*>(addr & -page_size);
       uintptr_t end = (addr + len + page_size - 1) & -page_size;
       return mprotect(start, end - reinterpret_cast<uintptr_t>(start), prot);};
   if (VTable && (VTable[kill_message_event_idx] != kill_message_event)) {
        orig_kill_message_event = decltype(orig_kill_message_event)(VTable[kill_message_event_idx]);
		LOGE("vtable Offset %lx",(uintptr_t) VTable[kill_message_event_idx] - Cheat::libUE4Base);
        f_mprotect((uintptr_t)(&VTable[kill_message_event_idx]), sizeof(uintptr_t), PROT_READ | PROT_WRITE);
        VTable[kill_message_event_idx] = (void *) kill_message_event;
	}
    //===================================================================================================================//
    if (g_LocalPlayer && g_LocalPlayer->AvatarComponent2) {
        auto AvatarComp = g_LocalPlayer->AvatarComponent2;
        auto* NetAvatarComp = (FNetAvatarSyncData*)((uintptr_t)AvatarComp + 0x3E8);
    if (!NetAvatarComp) return;
        auto& Slotsybc = NetAvatarComp->SlotSyncData;
        bool updated = false;
        int selectedSuitIndex = g_PlayerOutfit.currentOutfit.load();
    if (selectedSuitIndex >= 0 && selectedSuitIndex < IM_ARRAYSIZE(g_Outfits)) {
        int desiredItemId = g_Outfits[selectedSuitIndex].itemId;
    if (Slotsybc.Num() > 2 && Slotsybc[2].ItemId != desiredItemId) {
        Slotsybc[2].ItemId = desiredItemId;
        updated = true;
    }}
    if (updated) {
        g_LocalPlayer->AvatarComponent2->OnRep_BodySlotStateChanged();
    }}
    //===================================================================================================================//
    if (!g_LocalPlayer || !g_LocalPlayer->AvatarComponent2) return;
        auto* NetAvatarComp = (FNetAvatarSyncData*)((uintptr_t)g_LocalPlayer->AvatarComponent2 + 0x3E8);
    if (!NetAvatarComp) return;
        auto& Slots = NetAvatarComp->SlotSyncData;
        bool updated = false;
        for (int i = 0; i < Slots.Num(); i++) {
        int& id = Slots[i].ItemId;
        auto findNewId = [&](const auto& map) -> bool {
        auto it = map.find(id);
    if (it != map.end() && id != it->second) {
        id = it->second;
        updated = true;
        return true;
    } else {
        return false;
    }};
    if (findNewId(Bagpack) || findNewId(Helmet) || findNewId(Parachute)) {
        continue;
    }}
    if (updated) {
        g_LocalPlayer->AvatarComponent2->OnRep_BodySlotStateChanged();
    }
	//===================================================================================================================//
	if (VehicleSkin && g_LocalPlayer && g_LocalPlayer->CurrentVehicle) {
        auto* CurrentVehicle = g_LocalPlayer->CurrentVehicle;
    if ((uintptr_t)CurrentVehicle != lastVehicle) {
        lastVehicle = (uintptr_t)CurrentVehicle;
        lastSkinApplied = -1; // Reset skin
    }
    if (auto* VehicleAvatar = CurrentVehicle->VehicleAvatar) {
        int DefaultAvatarID = VehicleAvatar->GetDefaultAvatarID();
        int CurrentSkinID = CurrentVehicle->GetAvatarID();
        auto it = VehicleSkinMap.find(DefaultAvatarID);
    if (it != VehicleSkinMap.end()) {
        int DesiredSkinID = it->second;
    if (DesiredSkinID != CurrentSkinID && lastSkinApplied != DesiredSkinID) {
        lastSkinApplied = DesiredSkinID;
        VehicleAvatar->ChangeItemAvatar(DesiredSkinID, true);
    }}}}
    //===================================================================================================================//
    if (GunSkin && g_LocalPlayer) {
        auto* WeaponManager = g_LocalPlayer->WeaponManagerComponent;
    if (WeaponManager) {
        auto propSlot = WeaponManager->GetCurrentUsingPropSlot();
    if ((int)propSlot.GetValue() < 1 || (int)propSlot.GetValue() > 4) return;
        auto* Weapon = WeaponManager->CurrentWeaponReplicated;
        auto& UnrealHacks = Weapon->synData;
    if (UnrealHacks.Num() > 0) {
        int weaponID = Weapon->GetWeaponID();
        std::unordered_map<int, int>* currentWeaponMap = nullptr;
        switch (weaponID) {
        case 101004: currentWeaponMap = &M416SkinsID; break;
        case 101001: currentWeaponMap = &AKMSkinsID; break;
        case 101002: currentWeaponMap = &M16A4SkinsID; break;
        case 101003: currentWeaponMap = &SCARLSkinsID; break;
        case 101005: currentWeaponMap = &GROZASkinsID; break;
        case 101006: currentWeaponMap = &AUGSkinsID; break;
        case 101007: currentWeaponMap = &QBZSkinsID; break;
        case 101008: currentWeaponMap = &M762SkinsID; break;
        case 101102: currentWeaponMap = &ACE32SkinsID; break;
        case 103003: currentWeaponMap = &AWMSkinsID; break;
        case 103002: currentWeaponMap = &M24SkinsID; break;
        case 103001: currentWeaponMap = &KAR98KSkinsID; break;
        case 103012: currentWeaponMap = &AMRSkinsID; break;
        case 103007: currentWeaponMap = &MK14SkinsID; break;
        case 103004: currentWeaponMap = &SKSSkinsID; break;
        case 103009: currentWeaponMap = &SLRSkinsID; break;
        case 103006: currentWeaponMap = &MINI14SkinsID; break;
        case 103100: currentWeaponMap = &MK12SkinsID; break;
        case 105002: currentWeaponMap = &DP28SkinsID; break;
        case 105010: currentWeaponMap = &MG3SkinsID; break;
        case 105001: currentWeaponMap = &M249SkinsID; break;
        case 102001: currentWeaponMap = &UZISkinsID; break;
        case 102002: currentWeaponMap = &UMP45SkinsID; break;
        case 102003: currentWeaponMap = &VECTORSKinsID; break;
        case 102004: currentWeaponMap = &THOMPSONSkinsID; break;
        case 102005: currentWeaponMap = &BIZONSkinsID; break;
        case 103005: currentWeaponMap = &VSSSkinsID; break;
        case 102105: currentWeaponMap = &P90SkinsID; break;
        case 104003: currentWeaponMap = &S12KSkinsID; break;
        case 104002: currentWeaponMap = &S1897SkinsID; break;
        case 104004: currentWeaponMap = &DBSSkinsID; break;
        case 101012: currentWeaponMap = &HoneyBadgerSkinsID; break;
        case 101100: currentWeaponMap = &FAMASSkinsID; break;
        case 108004: currentWeaponMap = &PANSkinsID; break;
        case 108001: currentWeaponMap = &MacheteSkinsID; break;
        case 108005: currentWeaponMap = &DaggerSkinsID; break;
        default: break;
    }
    if (currentWeaponMap) {
        bool skinChanged = false;
        for (int i = 0; i < UnrealHacks.Num(); i++) {
        auto& entry = UnrealHacks[i];
        auto it = currentWeaponMap->find(entry.DefineID.TypeSpecificID);
    if (it != currentWeaponMap->end() && entry.DefineID.TypeSpecificID != it->second) {
        entry.DefineID.TypeSpecificID = it->second;
        skinChanged = true;
    }}
    if (skinChanged) {
        Weapon->OnRep_AvatarMeshChanged();
    }}}}}
    //===================================================================================================================//
	if (Cheat::MemoryHack::InstantHit) {
		Write_Float(Cheat::libUE4Base + 0x9C043A8, 8.95671814e-21);
	}
    //===================================================================================================================//
    if (Cheat::MemoryHack::SmallCrossHair && g_LocalPlayer->WeaponManagerComponent) {
    if (auto WeaponManagerComponent = g_LocalPlayer->WeaponManagerComponent) {
        auto propSlot = WeaponManagerComponent->GetCurrentUsingPropSlot();
  if ((int) propSlot.GetValue() >= 1 && (int) propSlot.GetValue() <= 3) {
    if (auto* CurrentWeapon = (ASTExtraShootWeapon*)g_LocalPlayer->WeaponManagerComponent->CurrentWeaponReplicated) {
    if (CurrentWeapon->ShootWeaponEntityComp) CurrentWeapon->ShootWeaponEntityComp->GameDeviationFactor = 0.0f;
    }}}}
    



    //===================================================================================================================//
	
    //===================================================================================================================//
}


void logout() {
        system("rm -rf /data/data/com.pubg.imobile/shared_prefs");
        system("mkdir /data/data/com.pubg.imobile/shared_prefs");
        system("chmod 777 /data/data/com.pubg.imobile/shared_prefs");
        system("rm -rf /data/data/com.pubg.imobile/databases");
        system("rm -rf /data/data/com.pubg.imobile/files/login-identifier.txt");
        system("rm -rf /data/data/com.pubg.imobile/files/UE4Game/ShadowTrackerExtra/ShadowTrackerExtra/Intermediate");
        system("rm -rf /data/data/com.pubg.imobile/files/UE4Game/ShadowTrackerExtra/ShadowTrackerExtra/Intermediate");
        system("rm -rf /data/data/com.pubg.imobile/files/TGPA");
        system("rm -rf /data/data/com.pubg.imobile/files/TGPA");
        system("rm -rf /data/data/com.pubg.imobile/files/ProgramBinaryCache");
        system("rm -rf /data/data/com.pubg.imobile/files/ProgramBinaryCache");
        system("chmod -R 000 /data/data/com.pubg.imobile/files/ano_tmp/ano.ano3.dat");

 }
