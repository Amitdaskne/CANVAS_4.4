__int64 __fastcall (*orig_PostRender)(UGameViewportClient* ViewportClient, UCanvas* Canvas);
__int64 __fastcall new_PostRender(UGameViewportClient* ViewportClient, UCanvas* Canvas) {
    if (!Canvas) 
        return 0;
    __int64 xCanvas = orig_PostRender(ViewportClient, Canvas);
    glWidth  = Canvas->SizeX;
    glHeight = Canvas->SizeY;
    static bool bFontLoaded = false;
    if (!tslFont || !robotoTinyFont) {
    if (!bFontLoaded) {std::thread([] { LoadFont(nullptr); }).detach(); bFontLoaded = true;}
       return 0;
    }
    DrawMSG(Canvas);
    LocalPlayer(Canvas);
    DrawPlayerESP(Canvas);
    MemoryHacksBy_uKnowSpidy();
 //   LobbySkins(Canvas);
	return xCanvas;
}
void PostRenderHook() {
    auto GViewport = GetGameViewport();

    if (GViewport && Cheat::libUE4Base) {
        uintptr_t TargetAddr = Cheat::libUE4Base + Cheat::PostRender_Offset;
        void** VTable = (void **)GViewport->VTable; 
        
        if (VTable) {
            int postrender_idx = -1;
            for (int i = 0; i < 250; i++) {
                if ((uintptr_t)VTable[i] == TargetAddr) {
                    postrender_idx = i;
                    break;
                }
            }

            if (postrender_idx != -1 && VTable[postrender_idx] != (void*)new_PostRender) {
                auto f_mprotect = [](uintptr_t addr, size_t len, int32_t prot) -> int32_t {
                    size_t page_size = 4096;
                    void* start = reinterpret_cast<void*>(addr & ~(page_size - 1));
                    return mprotect(start, page_size, prot);
                };
                orig_PostRender = (decltype(orig_PostRender))(VTable[postrender_idx]);

                f_mprotect((uintptr_t)(&VTable[postrender_idx]), sizeof(uintptr_t), PROT_READ | PROT_WRITE);
                VTable[postrender_idx] = (void *)new_PostRender;
            }
        }
    } 
    }
    



