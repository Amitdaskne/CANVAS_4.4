__attribute__((constructor))
void _init() {
    pthread_create(&t1, nullptr, main_thread, nullptr);
    pthread_detach(t1);
    pthread_create(&t2, nullptr, loda_thread, nullptr);
    pthread_detach(t2);
	pthread_create(&t3, nullptr, shake_thread, nullptr);
    pthread_detach(t3);
}


